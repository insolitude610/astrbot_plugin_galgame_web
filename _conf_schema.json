{
  "character_name": {
    "description": "角色显示名",
    "type": "string",
    "default": "",
    "hint": "在对话框上方显示的角色名称"
  },
  "web_port": {
    "description": "独立 WebUI 端口",
    "type": "int",
    "default": 6186,
    "hint": "插件将在该端口启动独立 WebUI。浏览器访问 http://localhost:<端口> 即可打开 Galgame 界面。设为 0 则不启动独立服务器。"
  },
  "persona": {
    "description": "角色人格",
    "type": "string",
    "_special": "select_persona",
    "hint": "选择已在 AstrBot 中配置好的人格。人格的 system prompt 将作为角色的性格设定。",
    "default": ""
  },
  "system_prompt_extra": {
    "description": "额外 System Prompt",
    "type": "text",
    "default": "",
    "hint": "追加在人格 prompt 之后，用于添加 Galgame 专属规则或微调"
  },
  "tts_provider": {
    "description": "TTS 语音合成 Provider",
    "type": "string",
    "_special": "select_provider_tts",
    "hint": "选择已配置的 TTS 提供商。推荐 Edge TTS（免费，零配置）或 OpenAI TTS。留空则不启用语音。",
    "default": ""
  },
  "llm_provider": {
    "description": "对话模型 Provider",
    "type": "string",
    "_special": "select_provider",
    "hint": "选择驱动角色对话的 AI 模型",
    "default": ""
  },
  "background": {
    "description": "场景背景图",
    "type": "string",
    "default": "",
    "hint": "assets/ 目录下的背景图文件名。留空则自动匹配 background.png / bg.png"
  },
  "rapid_click_threshold": {
    "description": "快速点击数阈值",
    "type": "int",
    "default": 5,
    "hint": "用户在检测窗口内点击超过此次数，AI 将主动关心用户"
  },
  "rapid_window_seconds": {
    "description": "快速点击检测窗口（秒）",
    "type": "int",
    "default": 3
  },
  "session_retain_days": {
    "description": "会话保留天数",
    "type": "int",
    "default": 7,
    "hint": "超过该天数的旧会话自动清理。设为 0 则永不清理"
  },
  "sprite_scale": {
    "description": "立绘缩放比例",
    "type": "float",
    "default": 1.0,
    "hint": "立绘整体缩放倍数。1.0 为原始大小，建议范围 0.5 ~ 2.0"
  },
  "sprite_bottom": {
    "description": "立绘底部位置",
    "type": "float",
    "default": 28.0,
    "hint": "立绘底部距离视口底部的 vh 距离。数值越小立绘越靠下（越低）。建议范围 5 ~ 45。配合缩放可避免穿帮。"
  },
  "sprite_left": {
    "description": "立绘水平位置",
    "type": "float",
    "default": 50.0,
    "hint": "立绘水平锚点在视口中的 % 位置。50=居中，<50=偏左，>50=偏右。建议范围 30 ~ 70。"
  },
  "sprite_mode": {
    "description": "立绘渲染模式",
    "type": "string",
    "options": ["single", "layered"],
    "default": "single",
    "hint": "single=单张立绘+表情差分；layered=多层PNG各自独立动画"
  },
  "expressions": {
    "description": "表情立绘路径",
    "type": "object",
    "hint": "key=情绪标签名, value=assets/目录下的文件名。留空=自动匹配。如需更多情绪，修改此对象中的key名即可。",
    "items": {
      "neutral":   {"description": "普通", "type": "string", "default": ""},
      "happy":     {"description": "开心", "type": "string", "default": ""},
      "sad":       {"description": "悲伤", "type": "string", "default": ""},
      "angry":     {"description": "生气", "type": "string", "default": ""},
      "surprised": {"description": "惊讶", "type": "string", "default": ""},
      "blush":     {"description": "害羞", "type": "string", "default": ""},
      "thinking":  {"description": "思考", "type": "string", "default": ""}
    }
  },
  "custom_emotions": {
    "description": "自定义情绪",
    "type": "text",
    "default": "",
    "editor_mode": true,
    "editor_language": "json",
    "hint": "JSON对象格式，用于添加额外情绪。例: {\"dokidoki\": \"\", \"cry\": \"cry.png\"}。key为情绪标签名，value为assets/下的文件名。会与上方expressions合并。"
  },
  "layers": {
    "description": "分层立绘 — 全部留空即可，插件自动检测 assets/ 目录",
    "type": "object",
    "hint": "将 PNG 上传到立绘管理页面(页面右上角⚙)即可零配置使用。手动填写可覆盖自动检测结果",
    "items": {
      "body":        {"description": "身体 (留空=自动)", "type": "string", "default": ""},
      "hair_back":   {"description": "头发后 (留空=自动)", "type": "string", "default": ""},
      "head":        {"description": "头部 (留空=自动)", "type": "string", "default": ""},
      "hair_front":  {"description": "头发前 (留空=自动)", "type": "string", "default": ""},
      "mouth_open":  {"description": "张嘴 (留空=自动)", "type": "string", "default": ""},
      "mouth_closed":{"description": "闭嘴 (留空=自动)", "type": "string", "default": ""},
      "orb":         {"description": "球体 (留空=自动)", "type": "string", "default": ""}
    }
  }
}
