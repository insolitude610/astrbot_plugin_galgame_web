{
  "character_name": {
    "description": "角色显示名",
    "type": "string",
    "default": "",
    "hint": "在对话框上方显示的角色名称"
  },
  "persona": {
    "description": "角色人格",
    "type": "string",
    "_special": "select_persona",
    "hint": "选择已在 AstrBot 中配置好的人格。人格的 system prompt 将作为角色的性格设定。",
    "default": ""
  },
  "system_prompt_extra": {
    "description": "额外 System Prompt",
    "type": "text",
    "default": "",
    "hint": "追加在人格 prompt 之后，用于添加 Galgame 专属规则或微调"
  },
  "tts_provider": {
    "description": "TTS 语音合成 Provider",
    "type": "string",
    "_special": "select_provider_tts",
    "hint": "选择已配置的 TTS 提供商。推荐 Edge TTS（免费，零配置）或 OpenAI TTS。留空则不启用语音。",
    "default": ""
  },
  "llm_provider": {
    "description": "对话模型 Provider",
    "type": "string",
    "_special": "select_provider",
    "hint": "选择驱动角色对话的 AI 模型",
    "default": ""
  },
  "background": {
    "description": "场景背景图",
    "type": "string",
    "default": "",
    "hint": "assets/ 目录下的背景图文件名。留空则自动匹配 background.png / bg.png"
  },
  "rapid_click_threshold": {
    "description": "快速点击数阈值",
    "type": "int",
    "default": 5,
    "hint": "用户在检测窗口内点击超过此次数，AI 将主动关心用户"
  },
  "rapid_window_seconds": {
    "description": "快速点击检测窗口（秒）",
    "type": "int",
    "default": 3
  },
  "session_retain_days": {
    "description": "会话保留天数",
    "type": "int",
    "default": 7,
    "hint": "超过该天数的旧会话自动清理。设为 0 则永不清理"
  },
  "sprite_mode": {
    "description": "立绘渲染模式",
    "type": "string",
    "options": ["single", "layered"],
    "default": "single",
    "hint": "single=单张立绘+表情差分；layered=多层PNG各自独立动画"
  },
  "expressions": {
    "description": "表情立绘映射",
    "type": "dict",
    "hint": "key=情绪名(如happy), value=assets/目录下的文件名。可在WebUI中自由增删情绪条目。留空则使用默认7种情绪。",
    "default": {
      "neutral": "",
      "happy": "",
      "sad": "",
      "angry": "",
      "surprised": "",
      "blush": "",
      "thinking": ""
    }
  },
  "layers": {
    "description": "分层立绘 — 全部留空即可，插件自动检测 assets/ 目录",
    "type": "object",
    "hint": "将 PNG 上传到立绘管理页面(页面右上角⚙)即可零配置使用。手动填写可覆盖自动检测结果",
    "items": {
      "body":        {"description": "身体 (留空=自动)", "type": "string", "default": ""},
      "hair_back":   {"description": "头发后 (留空=自动)", "type": "string", "default": ""},
      "head":        {"description": "头部 (留空=自动)", "type": "string", "default": ""},
      "hair_front":  {"description": "头发前 (留空=自动)", "type": "string", "default": ""},
      "mouth_open":  {"description": "张嘴 (留空=自动)", "type": "string", "default": ""},
      "mouth_closed":{"description": "闭嘴 (留空=自动)", "type": "string", "default": ""},
      "orb":         {"description": "球体 (留空=自动)", "type": "string", "default": ""}
    }
  }
}
