{
  "character_name": {
    "description": "角色名",
    "type": "string",
    "default": "小星"
  },
  "character_role": {
    "description": "角色性格描述",
    "type": "text",
    "default": "一个友善的AI虚拟伙伴，喜欢聊天和分享日常，说话温柔亲切",
    "hint": "会被写入 system prompt，定义角色的说话风格和性格"
  },
  "system_prompt_extra": {
    "description": "额外 System Prompt",
    "type": "text",
    "default": "",
    "hint": "追加在默认模板之后，用于添加角色背景故事、特殊设定等"
  },
  "tts_provider": {
    "description": "TTS 语音合成 Provider",
    "type": "string",
    "_special": "select_provider_tts",
    "hint": "选择已配置的 TTS 提供商。推荐 Edge TTS（免费，零配置）或 OpenAI TTS。留空则不启用语音。",
    "default": ""
  },
  "llm_provider": {
    "description": "对话模型 Provider",
    "type": "string",
    "_special": "select_provider",
    "hint": "选择驱动角色对话的 AI 模型",
    "default": ""
  },
  "background": {
    "description": "场景背景图",
    "type": "string",
    "default": "",
    "hint": "assets/ 目录下的背景图文件名，留空则显示纯色背景"
  },
  "rapid_click_threshold": {
    "description": "快速点击数阈值",
    "type": "int",
    "default": 5,
    "hint": "用户在检测窗口内点击超过此次数，AI 将主动关心用户"
  },
  "rapid_window_seconds": {
    "description": "快速点击检测窗口（秒）",
    "type": "int",
    "default": 3
  },
  "sprite_mode": {
    "description": "立绘渲染模式",
    "type": "string",
    "options": ["single", "layered"],
    "default": "single",
    "hint": "single=单张立绘+表情差分；layered=多层PNG各自独立动画"
  },
  "expressions": {
    "description": "表情立绘路径",
    "type": "object",
    "hint": "对应 assets/ 目录下的 PNG 文件。至少填写 neutral",
    "items": {
      "neutral":   {"description": "普通表情", "type": "string", "default": ""},
      "happy":     {"description": "开心表情", "type": "string", "default": ""},
      "sad":       {"description": "悲伤表情", "type": "string", "default": ""},
      "angry":     {"description": "生气表情", "type": "string", "default": ""},
      "surprised": {"description": "惊讶表情", "type": "string", "default": ""},
      "blush":     {"description": "害羞表情", "type": "string", "default": ""},
      "thinking":  {"description": "思考表情", "type": "string", "default": ""}
    }
  },
  "layers": {
    "description": "分层立绘路径（仅 layered 模式生效）",
    "type": "object",
    "items": {
      "body":        {"description": "身体层", "type": "string", "default": ""},
      "hair_back":   {"description": "头发后层", "type": "string", "default": ""},
      "head":        {"description": "头部层（含五官）", "type": "string", "default": ""},
      "hair_front":  {"description": "头发前层", "type": "string", "default": ""},
      "mouth_open":  {"description": "张嘴差分", "type": "string", "default": ""},
      "mouth_closed":{"description": "闭嘴差分", "type": "string", "default": ""},
      "orb":         {"description": "漂浮球体", "type": "string", "default": ""}
    }
  }
}
